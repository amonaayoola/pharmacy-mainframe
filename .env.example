# ─────────────────────────────────────────────────────────────────────────────
# Pharmacy Intelligence Mainframe — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=generate-a-32-char-random-string-here
BRANCH_NAME=HealthBridge Lagos — Branch 001

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://pharmacy_user:pharmacy_pass@localhost:5432/pharmacy_mainframe
DB_PASSWORD=change-this-in-production

# ─── Redis (Caching) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=change-this-in-production

# ─── FX Rates ─────────────────────────────────────────────────────────────────
# AbokiFX API (parallel market rates)
ABOKIFX_URL=https://abokifx.com/api/v1/rates/unofficial
FX_FALLBACK_RATE=1578.0          # Used if AbokiFX API is down
FX_UPDATE_INTERVAL_HOURS=6       # How often to refresh the rate

# ─── NAFDAC Integration ───────────────────────────────────────────────────────
# Register at: https://api.nafdac.gov.ng/developers
NAFDAC_API_URL=https://api.nafdac.gov.ng/v1
NAFDAC_API_KEY=your-nafdac-api-key-here

# ─── WhatsApp (choose one provider) ──────────────────────────────────────────
WHATSAPP_PROVIDER=meta   # "meta" or "twilio"

# Option A: Meta Cloud API (recommended — free tier available)
# Get from: https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token

# Option B: Twilio WhatsApp Business
# Get from: https://www.twilio.com/whatsapp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Pharmacy Settings ────────────────────────────────────────────────────────
DEFAULT_MARGIN=0.25              # 25% profit margin target
LOW_STOCK_THRESHOLD_DAYS=7      # Alert when < 7 days of stock remain
EXPIRY_WARN_DAYS=90              # Flag items expiring within 90 days
REFILL_REMINDER_DAYS=3           # Send WhatsApp 3 days before refill due
AUTO_PO_ENABLED=true             # Automated purchase order generation
AUTO_PO_THRESHOLD_DAYS=7        # Create PO when stock falls below 7 days

# ─── Claude AI — FX Volatility Oracle ────────────────────────────────────────
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Trigger Claude analysis when the Naira swings by this % in one 6-hour window
FX_VOLATILITY_THRESHOLD_PCT=2.0

# Set to false to disable AI alerts without removing the API key
FX_ALERT_ENABLED=true

# ─── CORS Origins ─────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000","https://healthbridge.ng"]
